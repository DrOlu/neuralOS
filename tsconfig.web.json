{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "types": ["vite/client"]
  },
  "include": [
    "packages/ui/src/renderer_v2/**/*",
    "packages/mobile-web/src/**/*",
    "packages/shared/src/**/*",
    "apps/mobile-web/src/**/*",
    "apps/mobile-web/vite.config.ts",
    "apps/electron/src/preload/index.d.ts"
  ]
}
