{
  "name": "gyshell",
  "version": "0.1.6",
  "description": "GyShell - AI-Native Terminal App",
  "main": "./out/main/index.js",
  "author": "TUOTUO",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:electron": "electron-vite dev --config apps/electron/electron.vite.config.ts",
    "dev": "electron-vite dev --config apps/electron/electron.vite.config.ts",
    "start": "electron-vite preview --config apps/electron/electron.vite.config.ts",
    "start:electron": "electron-vite preview --config apps/electron/electron.vite.config.ts",
    "build:electron": "electron-vite build --config apps/electron/electron.vite.config.ts",
    "build": "electron-vite build --config apps/electron/electron.vite.config.ts",
    "build:backend": "npm --workspace @gyshell/gybackend run build",
    "start:backend": "npm --workspace @gyshell/gybackend run start",
    "typecheck:backend": "npm --workspace @gyshell/gybackend run typecheck",
    "build:tui": "npm --workspace @gyshell/tui run build",
    "dev:tui": "npm --workspace @gyshell/tui run dev --",
    "dev:mobile-web": "npm --workspace @gyshell/mobile-web run dev",
    "start:tui": "npm --workspace @gyshell/tui run start --",
    "start:mobile-web": "npm --workspace @gyshell/mobile-web run preview",
    "test:tui": "npm --workspace @gyshell/tui run test:smoke",
    "test:tui-input-automation": "npm --workspace @gyshell/tui run test:input-automation",
    "typecheck:tui": "npm --workspace @gyshell/tui run typecheck",
    "typecheck:mobile-web": "npm --workspace @gyshell/mobile-web run typecheck",
    "build:cli-binaries": "npm --workspace @gyshell/tui run build:cli-binaries",
    "build:mobile-web": "npm --workspace @gyshell/mobile-web run build",
    "build:all": "npm run build:electron && npm run build:backend && npm run build:tui",
    "prepare:cli-runtime": "node apps/electron/prepare-cli-runtime.mjs",
    "typecheck:all": "npm run typecheck && npm run typecheck:backend && npm run typecheck:tui && npm run typecheck:mobile-web",
    "dist": "npm run build:backend && npm run build:electron && npm run prepare:cli-runtime && electron-builder --config apps/electron/electron-builder.yml",
    "dist:mac": "npm run build:backend && export CSC_IDENTITY_AUTO_DISCOVERY=false && npm run build:electron && npm run prepare:cli-runtime -- --target darwin-arm64 && electron-builder --config apps/electron/electron-builder.yml --mac --dir && bash apps/electron/scripts/fix-mac-signatures.sh && electron-builder --config apps/electron/electron-builder.yml --mac --prepackaged dist/mac-arm64",
    "dist:win": "npm run build:backend && npm run build:electron && npm run prepare:cli-runtime -- --target windows-x64 && electron-builder --config apps/electron/electron-builder.yml --win --x64",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test:backend-regression": "node tests/backend-regression-tests.cjs",
    "test:backend-extreme": "node tests/backend-extreme-tests.cjs",
    "test:cli-install": "node tests-cli-install.cjs",
    "lint": "eslint .",
    "format": "prettier --write .",
    "rebuild:native": "electron-rebuild -f",
    "postinstall": "electron-builder install-app-deps && npm run rebuild:native"
  },
  "dependencies": {
    "@langchain/core": "^1.1.8",
    "@langchain/langgraph": "^1.0.7",
    "@langchain/mcp-adapters": "^1.1.1",
    "@langchain/openai": "^1.2.0",
    "@modelcontextprotocol/sdk": "^1.2.1",
    "@types/ssh2": "^1.15.5",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/headless": "^6.0.0",
    "@xterm/xterm": "^6.0.0",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.19",
    "diff": "^8.0.3",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.6.0",
    "i18next": "^25.7.4",
    "langchain": "^1.2.3",
    "lucide-react": "^0.562.0",
    "mobx": "^6.13.5",
    "mobx-react-lite": "^4.0.7",
    "node-pty": "1.2.0-beta.3",
    "pdf-parse": "^1.1.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^16.5.2",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^3.0.6",
    "remark-gfm": "^4.0.1",
    "remeda": "^2.33.4",
    "socks": "^2.8.7",
    "ssh2": "^1.17.0",
    "tree-sitter-bash": "^0.25.1",
    "uuid": "^9.0.0",
    "web-tree-sitter": "^0.26.3",
    "ws": "^8.19.0",
    "zod": "^3.25.32"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.0",
    "@types/node": "^20.0.0",
    "@types/pdf-parse": "^1.1.4",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/uuid": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.49.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "electron-vite": "^4.0.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.7.4",
    "sass": "^1.91.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.10"
  }
}
