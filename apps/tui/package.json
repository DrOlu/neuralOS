{
  "name": "@gyshell/tui",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Standalone GyShell terminal UI client",
  "bin": {
    "gyll": "./bin/gyll.cjs",
    "gyll-tui": "./bin/gyll.cjs"
  },
  "optionalDependencies": {
    "@gyshell/tui-darwin-arm64": "0.1.0",
    "@gyshell/tui-darwin-x64": "0.1.0",
    "@gyshell/tui-linux-arm64": "0.1.0",
    "@gyshell/tui-linux-x64": "0.1.0",
    "@gyshell/tui-windows-x64": "0.1.0"
  },
  "files": [
    "bin/**/*",
    "dist/**/*",
    "README.md",
    "package.json"
  ],
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild src/index.tsx --bundle --platform=node --format=esm --conditions=browser --jsx=automatic --jsx-import-source=@opentui/solid --packages=external --outfile=dist/index.js",
    "build:cli-binaries": "bun run scripts/build-cli-binaries.ts",
    "start": "bun run --conditions=browser --preload @opentui/solid/preload src/index.tsx",
    "dev": "bun run --watch --conditions=browser --preload @opentui/solid/preload src/index.tsx",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test:smoke": "bun run --conditions=browser --preload @opentui/solid/preload src/index.tsx --help",
    "test:input-automation": "bun run --conditions=browser --preload @opentui/solid/preload scripts/input-automation.tsx"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "@opentui/core": "0.1.73",
    "@opentui/solid": "0.1.73",
    "bun": "^1.3.9",
    "esbuild": "^0.25.9",
    "solid-js": "1.9.9",
    "typescript": "^5.3.3",
    "ws": "^8.19.0"
  }
}
